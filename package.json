{
  "name": "yolo-elf",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 0.0.0.0 -Port 8766 -Reload",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 127.0.0.1 -Port 8766 -Reload",
    "dev:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 0.0.0.0 -Port 8766 -Reload",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 0.0.0.0 -Port 8766",
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 127.0.0.1 -Port 8766",
    "start:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run.ps1 -HostName 0.0.0.0 -Port 8766",
    "start:bg": "node ./scripts/start-server.mjs 8766 --host 0.0.0.0",
    "start:bg:lan": "node ./scripts/start-server.mjs 8766 --host 0.0.0.0",
    "tailscale": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/tailscale-serve.ps1 -Port 8766",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tests.ps1"
  }
}
